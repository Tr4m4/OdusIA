"""
FITP Tornei Scraper
Utilizza l'API ufficiale (Azure Functions) del Portale Unico Competizioni FITP
per recuperare i tornei di tennis e filtrarli per distanza.
"""

import requests
from geopy.distance import geodesic
from geopy.geocoders import Nominatim
import time
import logging
from dataclasses import dataclass
from typing import Optional
from datetime import datetime

logger = logging.getLogger(__name__)

# ─────────────────────────────────────────────────────────────────────────────
#  ZONE DI RICERCA PRE-CONFIGURATE
# ─────────────────────────────────────────────────────────────────────────────

ZONE = [
    {
        "nome": "Milano - Via Valsugana",
        "lat": 45.5017,    # Via Valsugana, Milano (zona N-E di Milano)
        "lon": 9.2359,
        "raggio_km": 20,
        "id_regione": 3,    # Lombardia
        "id_provincia": 0,  # 0 = tutte le province della regione
        "sigla_provincia_filter": None,  # Cerca in tutte le province Lombardia, poi filtra per distanza
    },
    {
        "nome": "Tortona",
        "lat": 44.8954,
        "lon": 8.8655,
        "raggio_km": 10,
        "id_regione": 1,    # Piemonte
        "id_provincia": 0,
        "sigla_provincia_filter": "AL",  # Pre-filtra solo prov. Alessandria prima del geocoding
    },
]

# ─────────────────────────────────────────────────────────────────────────────
#  CONFIG API FITP
# ─────────────────────────────────────────────────────────────────────────────

FITP_API_URL = "https://dp-myfit-test-function-v2.azurewebsites.net/api/v2/tornei/puc/list"
# Confirmed working via direct API test — 200 OK
DISCIPLINE_TENNIS_ID = 4332

HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/124.0.0.0 Safari/537.36"
    ),
    "Accept": "application/json, text/plain, */*",
    "Accept-Language": "it-IT,it;q=0.9,en-US;q=0.8",
    "Content-Type": "application/json",
    "Origin": "https://www.fitp.it",
    "Referer": "https://www.fitp.it/",
}


@dataclass
class Torneo:
    nome: str
    circolo: str
    localita: str
    provincia: str
    data_inizio: str
    data_fine: str
    stato: str
    link: str
    lat: Optional[float] = None
    lon: Optional[float] = None
    distanza_km: Optional[float] = None
    zona_riferimento: Optional[str] = None


# ─────────────────────────────────────────────────────────────────────────────
#  GEOCODING (cache locale per limitare le chiamate a Nominatim)
# ─────────────────────────────────────────────────────────────────────────────

# Cache pre-compilata con coordinate per le citta' piu' comuni nelle zone di interesse
# (evita troppe chiamate a Nominatim che ha un rate limit di 1req/sec)
_geo_cache: dict = {
    # Provincia di Milano
    "Milano,MI,Italia": (45.4642, 9.1900),
    "Sesto San Giovanni,MI,Italia": (45.5363, 9.2349),
    "Cinisello Balsamo,MI,Italia": (45.5596, 9.2148),
    "Cernusco sul Naviglio,MI,Italia": (45.5228, 9.3293),
    "Monza,MB,Italia": (45.5845, 9.2744),
    "Vimodrone,MI,Italia": (45.5001, 9.2849),
    "Segrate,MI,Italia": (45.4879, 9.2950),
    "Cologno Monzese,MI,Italia": (45.5302, 9.2782),
    "Liscate,MI,Italia": (45.4758, 9.3661),
    "Pioltello,MI,Italia": (45.5023, 9.3295),
    # Provincia di Alessandria (Tortona area)
    "Tortona,AL,Italia": (44.8954, 8.8655),
    "Alessandria,AL,Italia": (44.9133, 8.6154),
    "Novi Ligure,AL,Italia": (44.7614, 8.7901),
    "Castelnuovo Scrivia,AL,Italia": (44.9800, 8.8750),
    "Pontecurone,AL,Italia": (44.9567, 8.9133),
    "Voghera,PV,Italia": (44.9960, 9.0084),
    "Sale,AL,Italia": (44.9916, 8.8031),
    "Vigevano,PV,Italia": (45.3141, 8.8594),
    "Lecco,LC,Italia": (45.8566, 9.3954),
    "Castellanza,VA,Italia": (45.6236, 8.8980),
    "Varese,VA,Italia": (45.8186, 8.8254),
    "Como,CO,Italia": (45.8081, 9.0852),
    "Bergamo,BG,Italia": (45.6982, 9.6773),
    "Brescia,BS,Italia": (45.5416, 10.2118),
    "Torino,TO,Italia": (45.0703, 7.6869),
    "Novara,NO,Italia": (45.4468, 8.6222),
    "Asti,AT,Italia": (44.9001, 8.2062),
    "Verbania,VB,Italia": (45.9292, 8.5541),
}
_geocoder = Nominatim(user_agent="fitp-mcp-server/1.0")


def get_coords(localita: str, provincia: str) -> Optional[tuple]:
    """Ottieni le coordinate lat/lon di una locality italiana."""
    chiave = f"{localita},{provincia},Italia"
    if chiave in _geo_cache:
        return _geo_cache[chiave]
    try:
        time.sleep(1)  # rispetta i limiti Nominatim (1 req/sec)
        location = _geocoder.geocode(chiave, timeout=10)
        if location:
            coords = (location.latitude, location.longitude)
            _geo_cache[chiave] = coords
            return coords
        # Fallback: prova solo con il nome della città
        location2 = _geocoder.geocode(f"{localita}, Italia", timeout=10)
        if location2:
            coords = (location2.latitude, location2.longitude)
            _geo_cache[chiave] = coords
            return coords
    except Exception as e:
        logger.warning(f"Geocoding fallito per '{chiave}': {e}")
    _geo_cache[chiave] = None
    return None


def calcola_distanza(lat1: float, lon1: float, localita: str, provincia: str) -> Optional[float]:
    """Calcola la distanza in km tra il punto di riferimento e la locality del torneo."""
    # Se il torneo ha già le coordinate, usale direttamente
    coords = get_coords(localita, provincia)
    if coords is None:
        return None
    return round(geodesic((lat1, lon1), coords).km, 1)


# ─────────────────────────────────────────────────────────────────────────────
#  CHIAMATA API FITP
# ─────────────────────────────────────────────────────────────────────────────

def _build_payload(
    id_regione: int,
    id_provincia: int = 0,
    freetext: str = "",
    solo_prossimi: bool = True,
    disciplina_id: int = DISCIPLINE_TENNIS_ID,
    rows_to_skip: int = 0,
    fetch_rows: int = 100,
) -> dict:
    """Costruisce il payload JSON per la ricerca tornei."""
    oggi = datetime.now().strftime("%d/%m/%Y")
    return {
        "guid": "",
        "profilazione": "",
        "freetext": freetext,
        "id_regione": id_regione,
        "id_provincia": id_provincia if id_provincia else None,
        "id_stato": None,
        "id_disciplina": disciplina_id,
        "sesso": None,
        "data_inizio": oggi if solo_prossimi else None,
        "data_fine": None,
        "tipo_competizione": None,
        "categoria_eta": None,
        "id_classifica": None,
        "classifica": None,
        "massimale_montepremi": None,
        "id_area_regionale": None,
        "ambito": None,
        "rowstoskip": rows_to_skip,
        "fetchrows": fetch_rows,
        "sortcolumn": "data_inizio",
        "sortorder": "asc",
    }


def _chiama_api_fitp(payload: dict, session: requests.Session) -> list[dict]:
    """Chiama l'API FITP e restituisce la lista grezza dei tornei."""
    try:
        resp = session.post(FITP_API_URL, json=payload, timeout=20)
        resp.raise_for_status()
        data = resp.json()

        # La risposta reale ha la chiave "competizioni"
        if isinstance(data, list):
            return data
        if isinstance(data, dict):
            for key in ("competizioni", "tornei", "data", "results", "items", "competitions"):
                if key in data:
                    return data[key] or []
            return [data]
        return []
    except requests.HTTPError as e:
        logger.error(f"HTTP error API FITP: {e} – Status {e.response.status_code}")
        logger.debug(f"Response body: {e.response.text[:500]}")
        return []
    except Exception as e:
        logger.error(f"Errore chiamata API FITP: {e}")
        return []


def _parse_torneo(raw: dict) -> Optional[dict]:
    """Converte il dict raw in un dict normalizzato dal JSON API."""
    try:
        # I campi potrebbero avere nomi diversi - proviamo le varianti comuni
        def _get(*keys):
            for k in keys:
                v = raw.get(k)
                if v is not None and v != "":
                    return str(v).strip()
            return ""

        # Campi confermati dalla risposta API reale
        nome = _get("nome_torneo", "nome", "title")
        circolo = _get("tennisclub", "nome_circolo", "circolo", "club")
        localita = _get("citta", "localita", "city", "comune")
        provincia = _get("sigla_provincia", "provincia")
        data_inizio = _get("data_inizio", "startDate")
        data_fine = _get("data_fine", "endDate")
        stato = _get("stato", "status")
        # Usa il guid come identificatore per il link
        guid = raw.get("guid") or raw.get("id_torneo_digital") or ""
        link = (
            f"https://www.fitp.it/Tornei/Ricerca-tornei?guid={guid}"
            if guid
            else ""
        )
        # Coordinate (raramente presenti nell'API, ma gestiamo il caso)
        lat = raw.get("latitudine") or raw.get("lat")
        lon = raw.get("longitudine") or raw.get("lon")

        if not nome:
            return None
        return {
            "nome": nome,
            "circolo": circolo,
            "localita": localita,
            "provincia": provincia,
            "data_inizio": data_inizio,
            "data_fine": data_fine,
            "stato": stato,
            "link": link,
            "lat": float(lat) if lat else None,
            "lon": float(lon) if lon else None,
        }
    except Exception as e:
        logger.debug(f"Errore parsing torneo raw: {e} – dato: {raw}")
        return None


# ─────────────────────────────────────────────────────────────────────────────
#  FUNZIONE PRINCIPALE ESPORTATA
# ─────────────────────────────────────────────────────────────────────────────

def cerca_tornei_nelle_zone(
    solo_prossimi: bool = True,
    disciplina_id: int = DISCIPLINE_TENNIS_ID,
) -> dict[str, list[Torneo]]:
    """
    Cerca i tornei di tennis nelle zone pre-configurate (ZONE).
    Restituisce un dizionario {nome_zona: [Lista Torneo]}.
    """
    session = requests.Session()
    session.headers.update(HEADERS)

    risultati: dict[str, list[Torneo]] = {}

    for zona in ZONE:
        nome_zona = zona["nome"]
        risultati[nome_zona] = []
        lat_ref = zona["lat"]
        lon_ref = zona["lon"]
        raggio = zona["raggio_km"]
        prov_filter = zona.get("sigla_provincia_filter")  # es. "AL" per Tortona

        logger.info(f"Ricerca per zona: {nome_zona} (id_regione={zona['id_regione']})")

        # Pagina 1
        payload = _build_payload(
            id_regione=zona["id_regione"],
            id_provincia=zona.get("id_provincia", 0),
            solo_prossimi=solo_prossimi,
            disciplina_id=disciplina_id,
        )
        raw_list = _chiama_api_fitp(payload, session)

        # Pagina 2+ se 100 risultati (paginazione)
        if len(raw_list) == 100:
            payload2 = {**payload, "rowstoskip": 100}
            raw_list += _chiama_api_fitp(payload2, session)

        logger.info(f"  Tornei grezzi ottenuti: {len(raw_list)}")

        # Pre-filtra per provincia se configurato (riduce il numero di geocoding calls)
        if prov_filter:
            raw_list = [r for r in raw_list if r.get("sigla_provincia", "").upper() == prov_filter.upper()]
            logger.info(f"  Dopo filtro provincia {prov_filter}: {len(raw_list)}")

        # Parse e filtra per distanza
        parsed_no_dist = []  # tornei che non sono riuscito a geocodificare
        for raw in raw_list:
            parsed = _parse_torneo(raw)
            if not parsed:
                continue

            distanza = None
            if parsed["lat"] and parsed["lon"]:
                distanza = round(geodesic((lat_ref, lon_ref), (parsed["lat"], parsed["lon"])).km, 1)
            elif parsed["localita"]:
                distanza = calcola_distanza(lat_ref, lon_ref, parsed["localita"], parsed["provincia"])

            if distanza is not None:
                if distanza <= raggio:
                    risultati[nome_zona].append(Torneo(
                        nome=parsed["nome"],
                        circolo=parsed["circolo"],
                        localita=parsed["localita"],
                        provincia=parsed["provincia"],
                        data_inizio=parsed["data_inizio"],
                        data_fine=parsed["data_fine"],
                        stato=parsed["stato"],
                        link=parsed["link"],
                        lat=parsed["lat"],
                        lon=parsed["lon"],
                        distanza_km=distanza,
                        zona_riferimento=nome_zona,
                    ))
            else:
                parsed_no_dist.append(parsed)

        # Fallback: se geocoding ha fallito per tutti, includi con distanza N/D
        # SOLO se abbiamo gia' filtrato per provincia (per non inondare con tutta la regione)
        if len(risultati[nome_zona]) == 0 and parsed_no_dist and prov_filter:
            logger.warning(
                f"  Geocoding fallito per zona {nome_zona}. "
                f"Includo {len(parsed_no_dist)} tornei prov. {prov_filter} senza distanza."
            )
            for parsed in parsed_no_dist:
                risultati[nome_zona].append(Torneo(
                    nome=parsed["nome"],
                    circolo=parsed["circolo"],
                    localita=parsed["localita"],
                    provincia=parsed["provincia"],
                    data_inizio=parsed["data_inizio"],
                    data_fine=parsed["data_fine"],
                    stato=parsed["stato"],
                    link=parsed["link"],
                    lat=parsed["lat"],
                    lon=parsed["lon"],
                    distanza_km=None,
                    zona_riferimento=nome_zona,
                ))

        # Ordina per distanza crescente (None in fondo)
        risultati[nome_zona].sort(key=lambda x: (x.distanza_km is None, x.distanza_km or 9999))
        logger.info(f"  Tornei nella zona dopo filtro: {len(risultati[nome_zona])}")

    return risultati



def formatta_risultati(risultati: dict[str, list[Torneo]]) -> str:
    """Formatta i risultati in testo leggibile per l'AI."""
    if not risultati:
        return "Nessun torneo trovato."

    lines = []
    for zona, tornei in risultati.items():
        lines.append(f"\n{'='*60}")
        lines.append(f"ZONA: {zona}")
        lines.append(f"{'='*60}")
        if not tornei:
            lines.append("  Nessun torneo trovato in questa zona nei prossimi giorni.")
            continue
        for i, t in enumerate(tornei, 1):
            dist_str = f"{t.distanza_km} km" if t.distanza_km is not None else "distanza N/D"
            lines.append(f"\n  {i}. {t.nome}")
            if t.circolo:
                lines.append(f"     Circolo: {t.circolo}")
            if t.localita:
                lines.append(f"     Localita: {t.localita} ({t.provincia}) - {dist_str}")
            if t.data_inizio:
                lines.append(f"     Date: {t.data_inizio}" + (f" -> {t.data_fine}" if t.data_fine else ""))
            if t.stato:
                lines.append(f"     Stato: {t.stato}")
            if t.link:
                lines.append(f"     Link: {t.link}")

    return "\n".join(lines)
